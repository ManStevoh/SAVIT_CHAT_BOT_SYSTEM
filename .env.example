APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Super admin seeder (optional; used by SuperAdminSeeder)
# SUPER_ADMIN_EMAIL=superadmin@savit.local
# SUPER_ADMIN_PASSWORD=password

# Frontend origin for CORS (used when Next.js calls the API).
# Production (Vercel): https://savit-chat-bot-system.vercel.app
FRONTEND_URL=http://localhost:3000

# Stripe (payments and subscriptions)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
# Webhook signing secret from Stripe CLI or Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: trial days for new subscriptions (default 14)
STRIPE_TRIAL_DAYS=14
STRIPE_CURRENCY=usd

# Default free trial for new companies (plan slug from plans table, trial days)
# SUBSCRIPTION_DEFAULT_PLAN_SLUG=starter
# SUBSCRIPTION_DEFAULT_TRIAL_DAYS=14

# Comma-separated domains for Sanctum cookie auth.
# Production: savit-chat-bot-system.vercel.app,savitchat.savitglobalsolutions.com
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp & OpenAI: prefer Super Admin → Settings → Integrations (saved in DB).
# Env below is optional fallback when not set in admin UI.
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=savit_verify_token
# META_APP_SECRET=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=512

# Growth Engine — Social OAuth (redirect URI: {APP_URL}/oauth/growth/callback)
# Meta: reuse WhatsApp embedded app or set dedicated growth app credentials
# GROWTH_META_APP_ID=
# GROWTH_META_APP_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# GROWTH_DEFAULT_CURRENCY=KES
# GROWTH_CRM_HOURS_QUIET=24
# GROWTH_CRM_MAX_FOLLOW_UPS=2
# GROWTH_PORTFOLIO_PRUNE_DAYS=90
# Layer 1 data sources (optional)
# GROWTH_GA4_ENABLED=false
# GROWTH_GA4_MEASUREMENT_ID=
# GROWTH_GA4_API_SECRET=
# GROWTH_EMAIL_SYNC_ENABLED=false
# GROWTH_EMAIL_PROVIDER=mailchimp
