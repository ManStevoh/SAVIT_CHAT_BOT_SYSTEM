{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["resources/js/*"],
      "next/link": ["resources/js/shims/next-link.tsx"],
      "next/navigation": ["resources/js/shims/next-navigation.ts"],
      "next/font/google": ["resources/js/shims/next-font.ts"]
    }
  },
  "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx", "vite.config.js"]
}
