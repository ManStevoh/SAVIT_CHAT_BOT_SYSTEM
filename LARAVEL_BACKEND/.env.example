APP_NAME="Essem Chat"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
# Shared hosting: set true so schedule:run applies pending migrations every 5 min.
# Prefer one-shot: php artisan migrate:via-cron --force  (then leave false).
AUTO_MIGRATE=false
# Production (Inertia same-origin): APP_URL=https://essemchat.essemglobalsolutions.com

# Must match APP_URL for Inertia same-origin (checkout redirects, email links, Sanctum cookies).
FRONTEND_URL=http://localhost:8080
# Production: FRONTEND_URL=https://essemchat.essemglobalsolutions.com

# Stripe (payments and subscriptions)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
# Webhook signing secret from Stripe CLI or Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: trial days for new subscriptions (default 14)
STRIPE_TRIAL_DAYS=14
STRIPE_CURRENCY=usd

# Default free trial for new companies (plan slug from plans table, trial days)
# SUBSCRIPTION_DEFAULT_PLAN_SLUG=starter
# SUBSCRIPTION_DEFAULT_TRIAL_DAYS=14

# Comma-separated hostnames for Sanctum cookie auth (no https:// prefix).
# Local dev values below. Production:
# SANCTUM_STATEFUL_DOMAINS=essemchat.essemglobalsolutions.com
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080,::1
# API token lifetime in minutes (default 24 hours). Set null in .env to disable expiry.
SANCTUM_EXPIRATION=1440

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production HTTPS (required behind TLS reverse proxy):
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
# SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: jobs (WhatsApp, notifications, Growth Engine) require a worker.
# Run: php artisan queue:work --sleep=3 --tries=3
# Production: use Supervisor/systemd to keep the worker running, or QUEUE_CONNECTION=redis.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp & OpenAI: prefer Super Admin → Settings → Integrations (saved in DB).
# Env below is optional fallback when not set in admin UI.
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=essem_verify_token
# META_APP_SECRET=
# WHATSAPP_EMBEDDED_APP_ID=
# WHATSAPP_EMBEDDED_CONFIG_ID=
# WHATSAPP_EMBEDDED_APP_SECRET=
# WHATSAPP_EMBEDDED_REDIRECT_URI=https://your-domain.com/dashboard/settings
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=512

# Google Gemini / Nano Banana image generation (Growth posters, WhatsApp campaign art)
# Get a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Growth Engine — Social OAuth (redirect URI: {APP_URL}/oauth/growth/callback)
# Meta: reuse WhatsApp embedded app or set dedicated growth app credentials
# GROWTH_META_APP_ID=
# GROWTH_META_APP_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# GROWTH_DEFAULT_CURRENCY=KES
# GROWTH_CRM_HOURS_QUIET=24
# GROWTH_CRM_MAX_FOLLOW_UPS=2
# GROWTH_PORTFOLIO_PRUNE_DAYS=90
# Layer 1 data sources (optional)
# GROWTH_GA4_ENABLED=false
# GROWTH_GA4_MEASUREMENT_ID=
# GROWTH_GA4_API_SECRET=
# GROWTH_EMAIL_SYNC_ENABLED=false
# GROWTH_EMAIL_PROVIDER=mailchimp

# Cron (production): run Laravel scheduler every minute.
# * * * * * cd /path/to/LARAVEL_BACKEND && php artisan schedule:run >> /dev/null 2>&1
# Scheduled tasks: subscription expiry reminders, Growth post publishing, CRM follow-ups,
# Meta sync, portfolio recommendations — see bootstrap/app.php → withSchedule().
