# Laravel API URL. When set, dashboard uses real data from the backend unless NEXT_PUBLIC_USE_MOCK_API=true.
# Local: http://localhost:8000
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to true to use mock data instead of the API. When NEXT_PUBLIC_API_URL is set, real data is used by default.
NEXT_PUBLIC_USE_MOCK_API=false
